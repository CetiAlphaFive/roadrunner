# ares src/Makevars -- portable, no GNU-make extensions.
#
# RcppParallel linkage is satisfied by `LinkingTo: Rcpp, RcppParallel` in
# DESCRIPTION on every supported platform we know of (modern RcppParallel
# embeds TBB and resolves at link time without an explicit -L flag here).
# An earlier revision called `$(shell Rscript -e RcppParallel::RcppParallelLibs())`
# but on current systems that helper returns an empty string, and the
# `$(shell ...)` extension trips the CRAN "Writing R Extensions" portability
# warning. Drop the call entirely.
#
# -ffp-contract was dropped at v0.0.0.9012 after a run-to-run determinism
# check confirmed FMA-vectorised mul-add chains do not break bit-exact
# reproducibility between consecutive ares() calls in a single binary.

PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS)
CXX_STD = CXX17
